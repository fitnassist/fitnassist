{
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-production-2bff.up.railway.app/api/:path*"
    },
    {
      "source": "/trpc/:path*",
      "destination": "https://api-production-2bff.up.railway.app/trpc/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
