{
  "name": "@fitnassist/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./zod": "./src/generated/zod/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate; tsx scripts/fix-zod-imports.ts",
    "generate": "prisma generate; tsx scripts/fix-zod-imports.ts",
    "migrate": "prisma migrate dev",
    "push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "zod-prisma-types": "^3.1.8"
  }
