{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run db:generate && npm run build:api"
  },
  "deploy": {
    "startCommand": "npm run start -w @fitnassist/api",
    "healthcheckPath": "/trpc",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
