# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fitnassist?schema=public"

# Auth (Better Auth)
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-here"
BETTER_AUTH_URL="http://localhost:3001"

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Email (optional - will log to console if not set)
RESEND_API_KEY=""
FROM_EMAIL="noreply@fitnassist.co"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Google Maps (for location search)
GOOGLE_MAPS_API_KEY=""

# USDA FoodData Central (food database for calorie tracking)
# Get a free key at https://api.data.gov/signup/ (optional, DEMO_KEY used as fallback)
USDA_API_KEY=""

# Web Push (VAPID) - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@fitnassist.co"
