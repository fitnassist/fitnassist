{
  "name": "@fitnassist/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "tsx src/server.ts",
    "clean": "rm -rf node_modules dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@fitnassist/database": "*",
    "@fitnassist/schemas": "*",
    "@fitnassist/types": "*",
    "@fitnassist/utils": "*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "resend": "^6.9.2",
    "stripe": "^20.4.1",
    "superjson": "^2.2.0",
    "tsx": "^4.19.0",
    "twilio": "^5.13.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^16.6.1",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
